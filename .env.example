# Database
DATABASE_URL=postgresql://user:password@localhost:5432/djzs

# WalletConnect (optional, uses default if not set)
VITE_WALLETCONNECT_PROJECT_ID=your-project-id

# XMTP Agent Configuration
# Set XMTP_ENV to "dev" (testnet) or "production" (mainnet)
XMTP_ENV=dev
# Agent.createFromEnv reads standard env vars for key material.
# Use the XMTP docs' env format for your agent wallet / keys.
# Example: XMTP_PRIVATE_KEY=your-agent-wallet-private-key

# Paragraph Newsletter API (optional)
PARAGRAPH_API_KEY=your-paragraph-api-key

# Optional: NFT Gating and Chain Configuration
VITE_MEMBERSHIP_NFT_ADDRESS=0x0000000000000000000000000000000000000000
VITE_CHAIN_ID=8453
VITE_RPC_URL=https://mainnet.base.org
