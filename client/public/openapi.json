        "tags": ["Audit"],
        "parameters": [
          {
            "name": "X-402-Payment",
            "in": "header",
            "required": true,
            "description": "x402 payment proof for $50.00 USDC on Base Mainnet",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
