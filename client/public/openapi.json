{
  "openapi": "3.1.0",
  "info": {
    "title": "DJZS Autonomous Auditing System API",
    "description": "Deterministic verification primitive for autonomous agents. Mandates an 'Audit-Before-Act' loop gated by x402 payment middleware (USDC on Base Mainnet). Returns a Proof of Logic Certificate with binary PASS/FAIL verdict and deterministic DJZS-LF failure codes (S=Structural, E=Epistemic, I=Incentive, X=Execution). Three tiers: Micro ($2.50), Founder ($5.00), Treasury ($50.00).",
    "version": "2.0.0",
    "contact": {
      "name": "DJZS",
      "url": "https://dj-z-s.replit.app",
      "email": "hello@dj-z-s.box"
    },
    "license": {
      "name": "Proprietary"
    },
    "x-agent-discovery": "/.well-known/agent.json",
    "x-payment-protocol": "x402",
    "x-payment-currency": "USDC",
    "x-payment-chain": "base-mainnet",
    "x-treasury-address": "0xEc551A9e5598a030B46278fEbaDF798Ea8bA05FF"
  },
  "servers": [
    {
      "url": "https://dj-z-s.replit.app",
      "description": "Production"
    }
  ],
  "paths": {
    "/api/audit/micro": {
      "post": {
        "operationId": "microZoneAudit",
        "summary": "Micro-Zone Audit ($2.50 USDC)",
        "description": "High-frequency sanity checks for trading bots. Fast execution, binary risk scoring. Character limit: 1000.",
        "tags": ["Audit"],
        "parameters": [
          {
            "name": "X-402-Payment",
            "in": "header",
            "required": true,
            "description": "x402 payment proof for $2.50 USDC on Base Mainnet",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MicroAuditRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audit verdict returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment required — x402 payment proof missing or invalid"
          },
          "400": {
            "description": "Invalid request — strategy_memo missing or too short"
          }
        }
      }
    },
    "/api/audit/founder": {
      "post": {
        "operationId": "founderZoneAudit",
        "summary": "Founder Zone Audit ($5.00 USDC)",
        "description": "Strategic roadmap diligence for VC agents. Detects narrative drift and confirmation bias. Character limit: 5000.",
        "tags": ["Audit"],
        "parameters": [
          {
            "name": "X-402-Payment",
            "in": "header",
            "required": true,
            "description": "x402 payment proof for $5.00 USDC on Base Mainnet",
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FounderAuditRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audit verdict returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment required — x402 payment proof missing or invalid"
          },
          "400": {
            "description": "Invalid request — strategy_memo missing or too short"
          }
        }
      }
    },
