      }
    },
    "/api/audit/schema": {
      "get": {
        "operationId": "getAuditSchema",
        "summary": "Schema Discovery",
        "description": "Returns API capabilities, tier details, pricing, and integration instructions for autonomous agents.",
        "tags": ["Discovery"],
        "responses": {
          "200": {
            "description": "Schema and capability manifest",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SchemaResponse"
                }
              }
            }
          }
        }
      }
    },
    "/.well-known/agent.json": {
      "get": {
        "operationId": "getAgentManifest",
        "summary": "Agent Discovery Manifest",
        "description": "Machine-readable manifest for A2A agent discovery. Contains system identity, payment requirements, capabilities, and response schema.",
        "tags": ["Discovery"],
        "responses": {
          "200": {
            "description": "Agent manifest",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "MicroAuditRequest": {
        "type": "object",
        "required": ["strategy_memo"],
        "properties": {
          "strategy_memo": {
            "type": "string",
            "minLength": 20,
            "maxLength": 1000,
            "description": "The thesis, strategy, or decision to be audited"
          },
          "audit_type": {
            "type": "string",
            "enum": ["treasury", "founder_drift", "strategy", "general"],
            "default": "general",
            "description": "Type of adversarial audit to perform"
          }
        }
      },
      "FounderAuditRequest": {
        "type": "object",
        "required": ["strategy_memo"],
        "properties": {
          "strategy_memo": {
            "type": "string",
            "minLength": 20,
            "maxLength": 5000,
            "description": "The roadmap, strategy document, or founder thesis to be audited"
          },
          "audit_type": {
            "type": "string",
            "enum": ["treasury", "founder_drift", "strategy", "general"],
            "default": "general",
            "description": "Type of adversarial audit to perform"
          }
        }
      },
      "TreasuryAuditRequest": {
        "type": "object",
        "required": ["strategy_memo"],
        "properties": {
          "strategy_memo": {
            "type": "string",
            "minLength": 20,
            "description": "The capital deployment proposal or governance decision to be audited. No character limit."
          },
          "audit_type": {
            "type": "string",
            "enum": ["treasury", "founder_drift", "strategy", "general"],
            "default": "general",
            "description": "Type of adversarial audit to perform"
          }
        }
      },
      "AuditResponse": {
        "type": "object",
        "properties": {
          "audit_id": {
            "type": "string",
            "format": "uuid",
            "description": "Unique identifier for this audit"
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of audit execution"
          },
          "tier": {
            "type": "string",
            "enum": ["micro", "founder", "treasury"],
            "description": "Audit tier that was executed"
          },
          "risk_score": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Overall risk score (0 = low risk, 100 = critical risk)"
          },
          "primary_bias_detected": {
            "type": "string",
            "enum": ["FOMO", "Sunk_Cost", "Narrative_Reaction", "Authority_Bias", "Confirmation_Bias", "Recency_Bias", "None"],
            "description": "The dominant cognitive bias detected in the submitted thesis"
          },
          "logic_flaws": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/LogicFlaw"
            },
            "description": "Array of identified logic flaws with severity ratings"
          },
          "structural_recommendations": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Actionable recommendations to strengthen the thesis"
          },
          "cryptographic_hash": {
            "type": "string",
            "description": "SHA-256 hash of the audit payload for immutable record-keeping"
          }
        }
      },
      "LogicFlaw": {
        "type": "object",
        "properties": {
          "flaw_type": {
            "type": "string",
            "description": "Category of the logic flaw"
          },
          "severity": {
            "type": "string",
            "enum": ["low", "medium", "critical"],
            "description": "Severity rating of the flaw"
          },
          "explanation": {
            "type": "string",
            "description": "Detailed explanation of why this is a flaw"
          }
        }
      },
      "SchemaResponse": {
        "type": "object",
        "properties": {
          "service": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tiers": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "name": { "type": "string" },
                "endpoint": { "type": "string" },
                "price": { "type": "string" },
                "description": { "type": "string" },
                "memo_limit": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "securitySchemes": {
      "x402": {
        "type": "apiKey",
        "in": "header",
        "name": "X-402-Payment",
        "description": "x402 payment proof header. USDC micropayment on Base Mainnet. Amount varies by tier: Micro ($2.50), Founder ($5.00), Treasury ($50.00)."
      }
    }
  },
  "security": [
    {
      "x402": []
    }
  ],
  "tags": [
    {
      "name": "Audit",
      "description": "Adversarial logic audit endpoints. Each tier requires x402 payment proof."
    },
    {
      "name": "Discovery",
      "description": "Agent and schema discovery endpoints for A2A integration."
    }
  ]
}
