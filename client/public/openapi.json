          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/FounderAuditRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Audit verdict returned successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AuditResponse"
                }
              }
            }
          },
          "402": {
            "description": "Payment required — x402 payment proof missing or invalid"
          },
          "400": {
            "description": "Invalid request — strategy_memo missing or too short"
          }
        }
      }
    },
    "/api/audit/treasury": {
      "post": {
        "operationId": "treasuryZoneAudit",
