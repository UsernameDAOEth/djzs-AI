{
  "name": "djzs-subgraph",
  "version": "1.0.0",
  "description": "DJZS Protocol Subgraph — indexes trust scores, staking, escrow, and agent registry on Base Mainnet",
  "scripts": {
    "codegen": "graph codegen",
    "build": "graph codegen && graph build",
    "deploy": "graph deploy djzs-protocol/djzs-subgraph",
    "create-local": "graph create --node http://localhost:8020/ djzs-protocol/djzs-subgraph",
    "deploy-local": "graph deploy --node http://localhost:8020/ --ipfs http://localhost:5001 djzs-protocol/djzs-subgraph"
  },
  "dependencies": {
    "@graphprotocol/graph-cli": "^0.71.0",
    "@graphprotocol/graph-ts": "^0.35.1"
  }
}
